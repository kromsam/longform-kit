{
  "harper-ls": {
    "workspaceDictPath": ".harper/dictionary.txt",
    "ignoredLintsPath": ".harper/ignored-lints",
    "diagnosticSeverity": "hint",
    "dialect": "British",
    "isolateEnglish": false,
    "maxFileLength": 500000,
    "markdown": {
      "IgnoreLinkTitle": true
    },
    "linters": {
      "SpellCheck": true,
      "SpelledNumbers": false,
      "AnA": true,
      "SentenceCapitalization": true,
      "UnclosedQuotes": true,
      "WrongApostrophe": false,
      "LongSentences": true,
      "RepeatedWords": true,
      "Spaces": true,
      "CorrectNumberSuffix": true
    },
    "codeActions": {
      "ForceStable": true
    },
    "excludePatterns": [
      "**/.git/**",
      "**/.agents/**",
      "**/.cache/**",
      "**/.codex/**",
      "**/.github/**",
      "**/.harper/**",
      "**/.quarto/**",
      "**/.vale/**",
      "**/node_modules/**",
      "**/archive/**",
      "**/drafts/**",
      "**/feedback/**",
      "**/notes/**",
      "**/submissions/**",
      "**/vendor/**",
      "**/_extensions/**",
      "**/_site/**",
      "**/dist/**",
      "**/build/**",
      "**/output/**",
      "**/docs/**",
      "**/extensions/**",
      "**/filters/**",
      "**/references/**",
      "**/resources/**",
      "**/scripts/**",
      "**/style/**",
      "**/tests/**",
      "**/AGENTS.md",
      "**/CHANGELOG.md",
      "**/CODE_OF_CONDUCT.md",
      "**/CONTRIBUTING.md",
      "**/LICENSE",
      "**/README.md",
      "**/index.md",
      "**/*.html",
      "**/*.pdf",
      "**/*.docx"
    ]
  }
}
