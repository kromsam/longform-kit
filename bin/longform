#!/bin/sh
set -eu

ROOT=$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)
PROJECT="$ROOT"
QUARTO_BIN=${QUARTO:-${LONGFORM_QUARTO:-quarto}}
export LONGFORM_QUARTO="$QUARTO_BIN"

die() {
  printf 'longform: %s\n' "$*" >&2
  exit 1
}

require() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

run_quarto() {
  (cd "$PROJECT" && "$QUARTO_BIN" "$@")
}

run_project_tool() {
  run_quarto run scripts/project.ts "$@"
}

prepare_tex_cache() {
  cache="$ROOT/.cache/texmf"
  create_cache=false
  if [ -z "${TEXMFCACHE:-}" ]; then
    TEXMFCACHE=$cache
    create_cache=true
  fi
  if [ -z "${TEXMFVAR:-}" ]; then
    TEXMFVAR=$cache
    create_cache=true
  fi
  [ "$create_cache" = false ] || mkdir -p "$cache"
  export TEXMFCACHE TEXMFVAR
}

output_file() {
  run_project_tool info output-file
}

output_dir() {
  run_project_tool info output-dir
}

doctor() {
  require "$QUARTO_BIN"
  version=$($QUARTO_BIN --version)
  case "$version" in
    1.9.*) ;;
    *) die "Quarto 1.9.38 through 1.9.x is required; found $version" ;;
  esac
  patch=${version##*.}
  [ "$patch" -ge 38 ] || die "Quarto 1.9.38 or newer is required; found $version"
  require lualatex
  required_fonts=$(run_project_tool info required-fonts)
  if [ -n "$required_fonts" ]; then
    require fc-match
    old_ifs=$IFS
    IFS='
'
    for font in $required_fonts; do
      requested=$(printf '%s' "$font" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]')
      [ -n "$requested" ] || die "invalid required font family: $font"
      matched=$(fc-match -f '%{family}\n' "$font" | sed -n '1{s/,.*//;p;}')
      resolved=$(printf '%s' "$matched" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]')
      [ "$resolved" = "$requested" ] ||
        die "required font not available: $font (fc-match resolved: $matched)"
    done
    IFS=$old_ifs
    printf 'Required fonts available\n'
  fi
  "$QUARTO_BIN" pandoc --version | sed -n '1p'
  printf 'Quarto %s\n' "$version"
  printf 'LuaLaTeX available\n'
  if command -v zettlr >/dev/null 2>&1; then
    printf 'Zettlr available (optional)\n'
  else
    printf 'Zettlr not found (optional)\n'
  fi
}

promote() {
  source=$1
  destination=$2
  [ -f "$source" ] || die "expected build output not found: $source"
  mkdir -p "$(dirname "$destination")"
  cp "$source" "$destination"
  printf 'Wrote %s\n' "$destination"
}

render_single() {
  target=$1
  extension=$2
  profile=${3:-}
  [ "$target" != pdf ] || prepare_tex_cache
  base=$(output_file)
  final_dir=$(output_dir)
  final_name=$base
  [ "$profile" = binding ] && final_name="${base}-binding"
  stage=$(mktemp -d "${TMPDIR:-/tmp}/longform-kit.XXXXXX")
  trap 'rm -rf "$stage"' EXIT HUP INT TERM
  if [ -n "$profile" ]; then
    run_quarto render --profile "$profile" --to "$target" --output-dir "$stage"
  else
    run_quarto render --to "$target" --output-dir "$stage"
  fi
  source=
  for candidate in "$stage"/*."$extension"; do
    [ -f "$candidate" ] || continue
    source=$candidate
    break
  done
  [ -n "$source" ] || die "Quarto did not produce a .$extension file"
  promote "$source" "$PROJECT/$final_dir/$final_name.$extension"
  rm -rf "$stage"
  trap - EXIT HUP INT TERM
}

render_latex() {
  base=$(output_file)
  final_dir=$(output_dir)
  stage=$(mktemp -d "${TMPDIR:-/tmp}/longform-kit.XXXXXX")
  trap 'rm -rf "$stage"' EXIT HUP INT TERM
  run_quarto render --to latex --output-dir "$stage"
  source=$(find "$stage" -type f -name '*.tex' -print | sed -n '1p')
  [ -n "$source" ] || die "Quarto did not produce $base.tex"
  promote "$source" "$PROJECT/$final_dir/$base.tex"
  bundle="$PROJECT/$final_dir/$base-latex"
  rm -rf "$bundle"
  cp -R "$(dirname "$source")" "$bundle"
  rm -rf "$stage"
  trap - EXIT HUP INT TERM
}

build() {
  target=${1:-all}
  run_project_tool check
  case "$target" in
    all)
      render_single pdf pdf
      render_single pdf pdf binding
      render_single docx docx
      render_latex
      run_project_tool gfm
      ;;
    pdf)
      render_single pdf pdf
      render_single pdf pdf binding
      ;;
    docx) render_single docx docx ;;
    latex) render_latex ;;
    gfm) run_project_tool gfm ;;
    *) die "build expects all, pdf, docx, latex, or gfm" ;;
  esac
}

lint_sources() {
  found=0
  status=0
  if command -v vale >/dev/null 2>&1; then
    found=1
    find "$PROJECT/document" -type f -name '*.md' -exec vale {} + || status=$?
  fi
  if command -v harper-cli >/dev/null 2>&1; then
    found=1
    find "$PROJECT/document/manuscript" -type f -name '*.md' \
      -exec harper-cli lint -d british {} + || status=$?
  fi
  [ "$found" -eq 1 ] || printf 'No supported prose linter found; skipping lint\n'
  return "$status"
}

setup_project() {
  run_project_tool configure-references "$@"
  run_project_tool sync
  printf 'Longform Kit project initialized\n'
  printf 'Point Zettlr Preferences > Citations at the Better CSL JSON source above\n'
}

zettlr() {
  action=${1:-sync}
  case "$action" in
    sync) run_project_tool sync ;;
    install)
      destination=${HOME}/.local/bin/longform-zettlr
      mkdir -p "$(dirname "$destination")"
      cp "$ROOT/bin/longform-zettlr" "$destination"
      chmod +x "$destination"
      printf 'Installed %s\n' "$destination"
      printf 'Add this Zettlr custom export command: longform-zettlr\n'
      ;;
    *) die "zettlr expects sync or install" ;;
  esac
}

usage() {
  cat <<'EOF'
Usage: bin/longform COMMAND [ARGUMENT]

Commands:
  setup [--library FILE_OR_DIR --zotero-data-dir DIR --style STYLE]
                                Link local Zotero inputs and initialize adapters
  build [all|pdf|docx|latex|gfm]
  check                         Validate project structure and citations
  lint                          Run available prose linters
  doctor                        Check required local tools
  zettlr [sync|install]         Synchronize or install Zettlr integration
EOF
}

command=${1:-help}
shift || true
case "$command" in
  setup) setup_project "$@" ;;
  build) build "${1:-all}" ;;
  check) run_project_tool check ;;
  lint) lint_sources ;;
  doctor) doctor ;;
  zettlr) zettlr "${1:-sync}" ;;
  help|-h|--help) usage ;;
  *) usage >&2; die "unknown command: $command" ;;
esac
