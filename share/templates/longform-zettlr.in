#!/bin/sh
set -eu

[ "$#" -ge 1 ] || {
  printf 'Usage: longform-zettlr INPUT_FILE\n' >&2
  exit 2
}

directory=$(CDPATH='' cd -- "$(dirname -- "$1")" && pwd)
while [ "$directory" != / ]; do
  if [ -f "$directory/_quarto.yml" ] && [ -x "$directory/../bin/longform" ]; then
    exec "$directory/../bin/longform" build all
  fi
  directory=$(dirname "$directory")
done

printf 'longform-zettlr: no Longform Kit project found above %s\n' "$1" >&2
exit 1
